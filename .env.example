# ─── Domain ──────────────────────────────────────────────────────────────────
# Used as the Traefik Host rule and for canonical URL generation.
SITE_DOMAIN=yourdomain.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=
AUTH_URL=https://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Password for the Postgres container (used by docker-compose db service)
DB_PASSWORD=

# ─── Public vars (also passed as build args in docker-compose.yml) ────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_GA4_ID=          # optional — Google Analytics 4 measurement ID
NEXT_PUBLIC_META_PIXEL_ID=   # optional — Meta Pixel ID

# ─── Webhooks ─────────────────────────────────────────────────────────────────
N8N_ORDER_WEBHOOK_URL=       # optional — n8n webhook for order/lead forwarding
